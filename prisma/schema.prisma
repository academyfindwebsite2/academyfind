model BlogPost {
  id String @id @default(cuid())

  title String
  slug  String @unique

  excerpt String?

  //-----------------------------------
  // Content
  //-----------------------------------

  contentMarkdown String @db.Text
  contentHtml     String @db.Text

  searchDocument String? @db.Text

  //-----------------------------------
  // Cover
  //-----------------------------------

  coverImage String?

  coverImageAlt String?

  coverImageWidth Int?

  coverImageHeight Int?

  //-----------------------------------
  // Reading Stats
  //-----------------------------------

  readingTime Int?

  wordCount Int?

  version Int @default(1)

  publishedVersion Int?

  featuredUntil DateTime?

  //-----------------------------------
  // Relations
  //-----------------------------------

  authorProfileId String?

  authorProfile BlogAuthorProfile? @relation(fields: [authorProfileId], references: [id])

  categoryId String?

  category BlogCategory? @relation(fields: [categoryId], references: [id])

  relatedInstituteId String?

  relatedInstitute Institute? @relation("InstituteBlogPosts", fields: [relatedInstituteId], references: [id])
  brandId          String?
  brand            BlogBrand? @relation("BlogBrandPosts", fields: [brandId], references: [id])
  //-----------------------------------
  // Workflow
  //-----------------------------------

  status          BlogStatus     @default(DRAFT)
  visibility      BlogVisibility @default(PUBLIC)
  rejectionReason String?

  //-----------------------------------
  // Audit Trail
  //-----------------------------------

  reviewedById String?

  reviewedBy User? @relation("PostReviewer", fields: [reviewedById], references: [id])

  publishedById String?

  publishedBy User? @relation("PostPublisher", fields: [publishedById], references: [id])

  lastEditedById String?

  lastEditedBy User? @relation("PostEditor", fields: [lastEditedById], references: [id])

  //-----------------------------------
  // Dates
  //-----------------------------------

  submittedAt DateTime?

  reviewedAt DateTime?

  publishedAt DateTime?

  scheduledAt DateTime?

  deletedAt DateTime?

  //-----------------------------------
  // SEO
  //-----------------------------------

  metaTitle String?

  metaDescription String?

  focusKeyword String?

  tableOfContents Json?

  canonicalUrl String?

  robotsIndex Boolean @default(true)

  robotsFollow Boolean @default(true)

  ogImage String?

  //-----------------------------------
  // Counters
  //-----------------------------------

  viewCount Int @default(0)

  likeCount Int @default(0)

  commentCount Int @default(0)

  bookmarkCount Int @default(0)

  //-----------------------------------
  // Display
  //-----------------------------------

  isFeatured Boolean @default(false)

  featuredOrder Int @default(0)

  isPinned Boolean @default(false)

  allowComments Boolean @default(true)

  //-----------------------------------
  // Timestamps
  //-----------------------------------

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  //-----------------------------------
  // Relations
  //-----------------------------------

  tags BlogPostTag[]

  comments BlogComment[]

  reactions BlogReaction[]

  slugHistory BlogSlugHistory[]

  revisions BlogRevision[]

  views BlogView[]

  bookmarks BlogBookmark[]

  reports BlogReport[]

  faqs BlogFAQ[]

  //-----------------------------------
  // Indexes
  //-----------------------------------

  @@index([slug])
  @@index([slug, status])
  @@index([status])
  @@index([publishedAt])
  @@index([status, publishedAt])
  @@index([categoryId, status, publishedAt])
  @@index([authorProfileId])
  @@index([brandId])
  @@index([relatedInstituteId])
  @@index([relatedInstituteId, status])
  @@index([isFeatured, featuredOrder])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([authorProfileId, status])
  @@index([categoryId, createdAt])
  @@index([status, visibility])
  @@map("blog_post")
}

