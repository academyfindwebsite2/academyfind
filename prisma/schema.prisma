generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String                    @id @default(cuid())
  name                     String?
  email                    String                    @unique
  phone                    String?
  passwordHash             String?
  image                    String?
  role                     Role                      @default(USER)
  isActive                 Boolean                   @default(true)
  emailVerified            Boolean                   @default(false)
  onboardingCompleted      Boolean                   @default(false)
  lastLoginAt              DateTime?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  canAddInstitute          Boolean                   @default(true)
  managedInstitutes        InstituteManager[]
  reviews                  Review[]
  accounts                 Account[]
  adminNotifications       AdminNotification[]
  communityAnswers         CommunityAnswer[]
  communityQuestions       CommunityQuestion[]
  claims                   InstituteClaim[]
  instituteRequests        InstituteRequest[]
  salesAssignments         SalesAssignment[]         @relation("SalesAssignments")
  salesCategoryAssignments SalesCategoryAssignment[] @relation("SalesCategoryAssignments")
  sessions                 Session[]
  payments                 SubscriptionPayment[]
  compareLists             UserCompareList[]
  viewHistory              UserHistory[]
  shortlisted              UserShortlist[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Institute {
  id                  String                     @id @default(cuid())
  name                String
  slug                String
  description         String?
  phone               String?
  email               String?
  website             String?
  address             String
  latitude            Float?
  longitude           Float?
  logo                String?
  coverImage          String?
  googlePlaceId       String?                    @unique
  googleRating        Float?
  googleReviewCount   Int?
  cityId              String
  isVerified          Boolean                    @default(false)
  isFeatured          Boolean                    @default(false)
  isActive            Boolean                    @default(true)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  imageUrl            String?
  averageRating       Float?                     @default(0)
  reviewCount         Int                        @default(0)
  googleMapsUrl       String?
  placeTypes          String[]
  gallery             String[]
  subscriptionPlan    SubscriptionPlan           @default(BASIC)
  youtubeVideos       String[]
  classroomImages     String[]
  feeInfo             String?
  planExpiresAt       DateTime?
  facebookUrl         String?
  instagramUrl        String?
  telegramUrl         String?
  twitterUrl          String?
  youtubeUrl          String?
  linkedinUrl         String?
  whatsappUrl         String?
  isPublished         Boolean                    @default(true)
  mode                InstituteMode              @default(OFFLINE)
  viewCount           Int                        @default(0)
  affiliations        String[]                   @default([])
  awards              String[]                   @default([])
  brochureUrl         String?
  compareCount        Int                        @default(0)
  cons                String[]                   @default([])
  establishedYear     Int?
  feeMax              Int?
  feeMin              Int?
  hasCertification    Boolean                    @default(false)
  hasDemoClasses      Boolean                    @default(false)
  hasHostelFacility   Boolean                    @default(false)
  hasOnlineClasses    Boolean                    @default(false)
  hasScholarship      Boolean                    @default(false)
  mediumOfInstruction String[]                   @default(["English", "Hindi"])
  metaDescription     String?
  metaTitle           String?
  pros                String[]                   @default([])
  refundPolicy        String?
  totalBranches       Int?
  totalStudents       Int?
  city                City                       @relation(fields: [cityId], references: [id])
  categories          InstituteCategory[]
  managers            InstituteManager[]
  reviews             Review[]
  communityQuestions  CommunityQuestion[]
  compareListItems    CompareListInstitute[]
  achievements        InstituteAchievement[]
  batches             InstituteBatch[]
  claims              InstituteClaim[]
  comparisonsAsFirst  InstituteComparisonCache[] @relation("ComparisonAsFirst")
  comparisonsAsSecond InstituteComparisonCache[] @relation("ComparisonAsSecond")
  dailyViews          InstituteDailyView[]
  enquiries           InstituteEnquiry[]
  facilities          InstituteFacility[]
  faqs                InstituteFAQ[]
  highlightStats      InstituteHighlightStat[]
  operatingHours      InstituteOperatingHour[]
  instituteRequest    InstituteRequest?
  notablepersons      NotablePersons[]
  salesAssignments    SalesAssignment?
  payments            SubscriptionPayment[]
  teachers            TeacherProfile[]
  viewHistory         UserHistory[]
  shortlistedBy       UserShortlist[]

  @@index([cityId])
  @@index([slug])
}

model City {
  id               String                @id @default(cuid())
  name             String
  slug             String                @unique
  state            String
  country          String                @default("India")
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  bannerImage      String?
  description      String?
  latitude         Float?
  longitude        Float?
  metaDescription  String?
  metaTitle        String?
  population       Int?
  institutes       Institute[]
  categoryContents CategoryCityContent[]

  @@index([state])
}

model Category {
  id                       String                    @id @default(cuid())
  name                     String
  slug                     String                    @unique
  parentId                 String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  isActive                 Boolean                   @default(true)
  level                    Int                       @default(0)
  bannerImage              String?
  description              String?
  icon                     String?
  metaDescription          String?
  metaTitle                String?
  shortDescription         String?
  parent                   Category?                 @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children                 Category[]                @relation("CategoryHierarchy")
  institutes               InstituteCategory[]
  cityContents             CategoryCityContent[]
  salesCategoryAssignments SalesCategoryAssignment[]

  @@index([parentId])
}

model CategoryCityContent {
  id               String   @id @default(cuid())
  categoryId       String
  cityId           String
  introContent     String?
  whyChooseContent String?
  metaTitle        String?
  metaDescription  String?
  h1Override       String?
  updatedAt        DateTime @updatedAt
  category         Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  city             City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([categoryId, cityId])
  @@index([categoryId])
  @@index([cityId])
  @@map("category_city_content")
}

model InstituteCategory {
  instituteId String
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@id([instituteId, categoryId])
  @@index([categoryId])
}

model InstituteManager {
  userId      String
  instituteId String
  createdAt   DateTime  @default(now())
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, instituteId])
  @@index([instituteId])
}

model Review {
  id          String       @id @default(cuid())
  rating      Int
  comment     String?
  userId      String
  instituteId String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  status      ReviewStatus @default(PENDING)
  institute   Institute    @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, instituteId])
  @@index([userId])
  @@index([instituteId])
}

model InstituteClaim {
  id          String    @id @default(cuid())
  instituteId String
  userId      String
  fullName    String
  email       String
  phone       String
  role        String
  message     String?
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([instituteId])
  @@index([userId])
  @@index([status])
  @@map("institute_claim")
}

model UserShortlist {
  userId      String
  instituteId String
  createdAt   DateTime  @default(now())
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, instituteId])
  @@map("user_shortlist")
}

model UserHistory {
  id          String    @id @default(cuid())
  userId      String
  instituteId String
  viewedAt    DateTime  @default(now()) @updatedAt
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, instituteId])
  @@index([userId])
  @@map("user_history")
}

model InstituteEnquiry {
  id          String    @id @default(cuid())
  instituteId String
  name        String
  phone       String
  message     String?
  status      String    @default("NEW")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@index([instituteId])
  @@map("institute_enquiry")
}

model TeacherProfile {
  id            String    @id @default(cuid())
  name          String
  subject       String?
  experience    String?
  imageUrl      String?
  instituteId   String
  qualification String?
  institute     Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@index([instituteId])
  @@map("teacher_profile")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_message")
}

model InstituteRequest {
  id          String    @id @default(cuid())
  userId      String
  instituteId String    @unique
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])

  @@map("institute_request")
}

model SubscriptionPayment {
  id            String           @id @default(cuid())
  instituteId   String
  userId        String?
  planRequested SubscriptionPlan
  billingCycle  String
  amountPaid    Int
  utrNumber     String           @unique
  proofImageUrl String?
  status        String           @default("PENDING")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  institute     Institute        @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user          User?            @relation(fields: [userId], references: [id])

  @@map("subscription_payment")
}

model SalesAssignment {
  id             String            @id @default(cuid())
  salesManagerId String
  instituteId    String            @unique
  contactStatus  ContactStatus     @default(NOT_CONTACTED)
  interest       InterestStatus?
  remark         String?
  onboardedPlan  SubscriptionPlan?
  deadline       DateTime?
  contactedAt    DateTime?
  onboardedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  institute      Institute         @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  salesManager   User              @relation("SalesAssignments", fields: [salesManagerId], references: [id], onDelete: Cascade)

  @@index([salesManagerId])
  @@index([instituteId])
  @@index([contactStatus])
  @@map("sales_assignment")
}

model SalesCategoryAssignment {
  id             String    @id @default(cuid())
  salesManagerId String
  categoryId     String
  deadline       DateTime?
  createdAt      DateTime  @default(now())
  category       Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  salesManager   User      @relation("SalesCategoryAssignments", fields: [salesManagerId], references: [id], onDelete: Cascade)

  @@unique([salesManagerId, categoryId])
  @@index([salesManagerId])
  @@map("sales_category_assignment")
}

model LifeCoachRequest {
  id        String                 @id @default(cuid())
  fullName  String
  phone     String
  email     String?
  message   String?
  status    LifeCoachRequestStatus @default(PENDING)
  createdAt DateTime               @default(now())
}

model AdminNotification {
  id          String   @id @default(cuid())
  type        String
  title       String
  message     String
  isRead      Boolean  @default(false)
  referenceId String?
  actionUrl   String?
  userId      String?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id])

  @@index([isRead])
  @@index([type])
  @@index([userId])
  @@map("admin_notification")
}

model JobPosting {
  id               String           @id @default(cuid())
  title            String
  slug             String           @unique
  department       String
  location         String
  type             String
  experience       String?
  description      String
  responsibilities String
  requirements     String
  benefits         String?
  isActive         Boolean          @default(true)
  Salary           String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  applications     JobApplication[]

  @@index([isActive])
  @@index([department])
  @@map("job_posting")
}

model JobApplication {
  id             String               @id @default(cuid())
  jobId          String
  name           String
  email          String
  phone          String
  linkedinUrl    String?
  portfolioUrl   String?
  resumeUrl      String
  coverLetter    String?
  status         JobApplicationStatus @default(NEW)
  notes          String?
  createdAt      DateTime             @default(now())
  resumeFileName String
  job            JobPosting           @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([status])
  @@map("job_application")
}

model GeneralResume {
  id             String   @id @default(cuid())
  name           String
  email          String
  phone          String
  linkedinUrl    String?
  portfolioUrl   String?
  resumeUrl      String
  resumeFileName String
  message        String?
  createdAt      DateTime @default(now())

  @@map("general_resume")
}

model InstituteDailyView {
  id          String    @id @default(cuid())
  instituteId String
  date        DateTime  @db.Date
  viewCount   Int       @default(0)
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@unique([instituteId, date])
  @@index([instituteId])
  @@map("institute_daily_view")
}

model InstituteFacility {
  id          String    @id @default(cuid())
  instituteId String
  name        String
  available   Boolean   @default(true)
  order       Int       @default(0)
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@index([instituteId])
  @@map("institute_facility")
}

model InstituteBatch {
  id          String        @id @default(cuid())
  instituteId String
  name        String
  duration    String?
  fee         Int?
  batchType   String?
  mode        InstituteMode @default(OFFLINE)
  timing      String?
  seatsTotal  Int?
  seatsLeft   Int?
  ageGroupMin Int?
  ageGroupMax Int?
  originalFee Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  institute   Institute     @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@index([instituteId])
  @@map("institute_batch")
}

model InstituteHighlightStat {
  id          String    @id @default(cuid())
  instituteId String
  label       String
  value       String
  icon        String?
  order       Int       @default(0)
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@index([instituteId])
  @@map("institute_highlight_stat")
}

model InstituteAchievement {
  id              String    @id @default(cuid())
  instituteId     String
  year            Int
  title           String
  studentName     String?
  achievementType String?
  imageUrl        String?
  institute       Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@index([instituteId])
  @@index([year])
  @@map("institute_achievement")
}

model InstituteFAQ {
  id          String    @id @default(cuid())
  instituteId String
  question    String
  answer      String
  order       Int       @default(0)
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@index([instituteId])
  @@map("institute_faq")
}

model InstituteOperatingHour {
  id          String    @id @default(cuid())
  instituteId String
  dayOfWeek   Int
  openTime    String?
  closeTime   String?
  isClosed    Boolean   @default(false)
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@unique([instituteId, dayOfWeek])
  @@index([instituteId])
  @@map("institute_operating_hour")
}

model UserCompareList {
  id        String                 @id @default(cuid())
  userId    String?
  sessionId String?
  shareSlug String?                @unique
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  items     CompareListInstitute[]
  user      User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([shareSlug])
  @@map("user_compare_list")
}

model CompareListInstitute {
  id            String          @id @default(cuid())
  compareListId String
  instituteId   String
  order         Int             @default(0)
  compareList   UserCompareList @relation(fields: [compareListId], references: [id], onDelete: Cascade)
  institute     Institute       @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@unique([compareListId, instituteId])
  @@index([instituteId])
  @@map("compare_list_institute")
}

model CommunityQuestion {
  id          String            @id @default(cuid())
  instituteId String
  userId      String
  question    String
  upvotes     Int               @default(0)
  createdAt   DateTime          @default(now())
  answers     CommunityAnswer[]
  institute   Institute         @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id])

  @@index([instituteId])
  @@map("community_question")
}

model CommunityAnswer {
  id         String            @id @default(cuid())
  questionId String
  userId     String
  answer     String
  upvotes    Int               @default(0)
  isVerified Boolean           @default(false)
  createdAt  DateTime          @default(now())
  question   CommunityQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id])

  @@index([questionId])
  @@map("community_answer")
}

model NotablePersons {
  id          String    @id @default(cuid())
  instituteId String
  name        String
  batchYear   Int?
  placedAt    String?
  package     String?
  imageUrl    String?
  createdAt   DateTime  @default(now())
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@index([instituteId])
  @@map("notable_alumni")
}

model InstituteComparisonCache {
  id              String    @id @default(cuid())
  institute1Id    String
  institute2Id    String
  slug            String    @unique
  summary         String?
  verdict         String?
  verdictReason   String?
  metaTitle       String?
  metaDescription String?
  viewCount       Int       @default(0)
  generatedAt     DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  institute1      Institute @relation("ComparisonAsFirst", fields: [institute1Id], references: [id], onDelete: Cascade)
  institute2      Institute @relation("ComparisonAsSecond", fields: [institute2Id], references: [id], onDelete: Cascade)

  @@unique([institute1Id, institute2Id])
  @@index([slug])
  @@map("institute_comparison_cache")
}

enum InstituteMode {
  OFFLINE
  ONLINE
  HYBRID
}

enum CategoryDomain {
  ACADEMIC
  PERFORMING_ARTS
  SPORTS
  VISUAL_ARTS
  FITNESS
  LANGUAGE
  OTHER
}

enum Role {
  USER
  CONTENT_WRITER
  INSTITUTE_MANAGER
  ADMIN
  SALES_MANAGER
}

enum SubscriptionPlan {
  BASIC
  PREMIUM
  ULTRA
  VERIFIED
}

enum ContactStatus {
  NOT_CONTACTED
  CONTACTED
  ONBOARDED
}

enum InterestStatus {
  INTERESTED
  NOT_INTERESTED
}

enum LifeCoachRequestStatus {
  PENDING
  CONTACTED
  RESOLVED
}

enum JobApplicationStatus {
  NEW
  REVIEWING
  SHORTLISTED
  REJECTED
  HIRED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}
