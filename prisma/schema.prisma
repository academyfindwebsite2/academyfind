generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String                    @id @default(cuid())
  name                     String?
  email                    String                    @unique
  phone                    String?
  passwordHash             String?
  image                    String?
  role                     Role                      @default(USER)
  isActive                 Boolean                   @default(true)
  emailVerified            Boolean                   @default(false)
  onboardingCompleted      Boolean                   @default(false)
  lastLoginAt              DateTime?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  canAddInstitute          Boolean                   @default(true)
  canWriteBlogs            Boolean                   @default(true)
  managedInstitutes        InstituteManager[]
  reviews                  Review[]
  accounts                 Account[]
  adminNotifications       AdminNotification[]
  communityAnswers         CommunityAnswer[]
  communityQuestions       CommunityQuestion[]
  claims                   InstituteClaim[]
  instituteRequests        InstituteRequest[]
  salesAssignments         SalesAssignment[]         @relation("SalesAssignments")
  salesCategoryAssignments SalesCategoryAssignment[] @relation("SalesCategoryAssignments")
  sessions                 Session[]
  payments                 SubscriptionPayment[]
  compareLists             UserCompareList[]
  viewHistory              UserHistory[]
  shortlisted              UserShortlist[]
  distributionLogs         LeadDistributionLog[]     @relation("AdminDistributionLogs")
  blogAuthorProfile        BlogAuthorProfile?
  blogComments             BlogComment[]
  blogReactions            BlogReaction[]
  blogViews                BlogView[]                @relation("UserBlogViews")
  blogBookmarks            BlogBookmark[]            @relation("UserBookmarks")
  followedAuthors          BlogAuthorFollower[]      @relation("UserFollowedAuthors")
  reviewedPosts            BlogPost[]                @relation("PostReviewer")
  publishedPosts           BlogPost[]                @relation("PostPublisher")
  editedPosts              BlogPost[]                @relation("PostEditor")
  blogRevisions            BlogRevision[]            @relation("RevisionAuthor")
  blogReports              BlogReport[]
  resolvedBlogReports      BlogReport[]              @relation("ResolvedBlogReports")

  studentProfile StudentProfile?
  teacherProfile TeacherProfile?

  memberships  InstituteMembership[]
  chatSettings ChatSettings?

  conversationParticipants ConversationParticipant[]
  messages                 Message[]
  messageReads             MessageRead[]
  messageReactions         MessageReaction[]

  messageReports         MessageReport[] @relation("Reporter")
  resolvedMessageReports MessageReport[] @relation("Resolver")

  blockedUsers         UserBlock[]    @relation("UserBlocks")
  blockedByUsers       UserBlock[]    @relation("BlockedUsers")
  createdConversations Conversation[]

  notifications UserNotification[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Institute {
  id                  String                     @id @default(cuid())
  name                String
  slug                String
  description         String?
  phone               String?
  email               String?
  website             String?
  address             String
  latitude            Float?
  longitude           Float?
  logo                String?
  coverImage          String?
  googlePlaceId       String?                    @unique
  googleRating        Float?
  googleReviewCount   Int?
  cityId              String
  isVerified          Boolean                    @default(false)
  isFeatured          Boolean                    @default(false)
  isActive            Boolean                    @default(true)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  imageUrl            String?
  averageRating       Float?                     @default(0)
  reviewCount         Int                        @default(0)
  googleMapsUrl       String?
  placeTypes          String[]
  gallery             String[]
  subscriptionPlan    SubscriptionPlan           @default(BASIC)
  youtubeVideos       String[]
  classroomImages     String[]
  feeInfo             String?
  planExpiresAt       DateTime?
  facebookUrl         String?
  instagramUrl        String?
  telegramUrl         String?
  twitterUrl          String?
  youtubeUrl          String?
  linkedinUrl         String?
  whatsappUrl         String?
  isPublished         Boolean                    @default(true)
  mode                InstituteMode              @default(OFFLINE)
  viewCount           Int                        @default(0)
  affiliations        String[]                   @default([])
  awards              String[]                   @default([])
  brochureUrl         String?
  compareCount        Int                        @default(0)
  cons                String[]                   @default([])
  establishedYear     Int?
  feeMax              Int?
  feeMin              Int?
  hasCertification    Boolean                    @default(false)
  hasDemoClasses      Boolean                    @default(false)
  hasHostelFacility   Boolean                    @default(false)
  hasOnlineClasses    Boolean                    @default(false)
  hasScholarship      Boolean                    @default(false)
  mediumOfInstruction String[]                   @default(["English", "Hindi"])
  metaDescription     String?
  metaTitle           String?
  pros                String[]                   @default([])
  refundPolicy        String?
  totalBranches       Int?
  totalStudents       Int?
  city                City                       @relation(fields: [cityId], references: [id])
  categories          InstituteCategory[]
  managers            InstituteManager[]
  reviews             Review[]
  communityQuestions  CommunityQuestion[]
  compareListItems    CompareListInstitute[]
  achievements        InstituteAchievement[]
  batches             InstituteBatch[]
  claims              InstituteClaim[]
  comparisonsAsFirst  InstituteComparisonCache[] @relation("ComparisonAsFirst")
  comparisonsAsSecond InstituteComparisonCache[] @relation("ComparisonAsSecond")
  dailyViews          InstituteDailyView[]
  enquiries           InstituteEnquiry[]
  facilities          InstituteFacility[]
  faqs                InstituteFAQ[]
  highlightStats      InstituteHighlightStat[]
  operatingHours      InstituteOperatingHour[]
  instituteRequest    InstituteRequest?
  notablepersons      NotablePersons[]
  salesAssignments    SalesAssignment?
  payments            SubscriptionPayment[]
  viewHistory         UserHistory[]
  shortlistedBy       UserShortlist[]
  blogPosts           BlogPost[]                 @relation("InstituteBlogPosts")
  memberships         InstituteMembership[]

  studentRecords StudentInstituteRecord[]
  teacherRecords TeacherInstituteRecord[]

  conversations Conversation[]

  @@index([cityId])
  @@index([slug])
}

model City {
  id               String                @id @default(cuid())
  name             String
  slug             String                @unique
  state            String
  country          String                @default("India")
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  bannerImage      String?
  description      String?
  latitude         Float?
  longitude        Float?
  metaDescription  String?
  metaTitle        String?
  population       Int?
  institutes       Institute[]
  categoryContents CategoryCityContent[]

  @@index([state])
}

model Category {
  id                       String                    @id @default(cuid())
  name                     String
  slug                     String                    @unique
  parentId                 String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  isActive                 Boolean                   @default(true)
  level                    Int                       @default(0)
  bannerImage              String?
  description              String?
  icon                     String?
  metaDescription          String?
  metaTitle                String?
  shortDescription         String?
  parent                   Category?                 @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children                 Category[]                @relation("CategoryHierarchy")
  institutes               InstituteCategory[]
  cityContents             CategoryCityContent[]
  salesCategoryAssignments SalesCategoryAssignment[]

  @@index([parentId])
}

model CategoryCityContent {
  id               String   @id @default(cuid())
  categoryId       String
  cityId           String
  introContent     String?
  whyChooseContent String?
  metaTitle        String?
  metaDescription  String?
  h1Override       String?
  updatedAt        DateTime @updatedAt
  category         Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  city             City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([categoryId, cityId])
  @@index([categoryId])
  @@index([cityId])
  @@map("category_city_content")
}

model InstituteCategory {
  instituteId String
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@id([instituteId, categoryId])
  @@index([categoryId])
}

model InstituteManager {
  userId      String
  instituteId String
  createdAt   DateTime  @default(now())
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, instituteId])
  @@index([instituteId])
}

model Review {
  id          String       @id @default(cuid())
  rating      Int
  comment     String?
  userId      String
  instituteId String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  status      ReviewStatus @default(PENDING)
  institute   Institute    @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, instituteId])
  @@index([userId])
  @@index([instituteId])
}

model InstituteClaim {
  id          String    @id @default(cuid())
  instituteId String
  userId      String
  fullName    String
  email       String
  phone       String
  role        String
  message     String?
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([instituteId])
  @@index([userId])
  @@index([status])
  @@map("institute_claim")
}

model UserShortlist {
  userId      String
  instituteId String
  createdAt   DateTime  @default(now())
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, instituteId])
  @@map("user_shortlist")
}

model UserHistory {
  id          String    @id @default(cuid())
  userId      String
  instituteId String
  viewedAt    DateTime  @default(now()) @updatedAt
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, instituteId])
  @@index([userId])
  @@map("user_history")
}

model InstituteEnquiry {
  id               String                @id @default(cuid())
  instituteId      String
  name             String
  phone            String
  email            String?
  message          String?
  status           String                @default("NEW")
  isForwarded      Boolean               @default(false)
  adminNote        String?               @db.Text
  parentId         String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  institute        Institute             @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  distributionLogs LeadDistributionLog[] @relation("DistributionLogs")

  @@index([instituteId])
  @@map("institute_enquiry")
}

model TeacherProfile {
  id               String                   @id @default(cuid())
  userId           String?                  @unique
  displayname      String?
  imageUrl         String?
  headline         String?
  bio              String?                  @db.Text
  qualification    String?
  experience       String?
  subjects         String[]                 @default([])
  languages        String[]                 @default([])
  allowDMs         Boolean                  @default(true)
  isVisible        Boolean                  @default(true)
  isVerified       Boolean                  @default(false)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @default(now()) @updatedAt
  user             User?                    @relation(fields: [userId], references: [id])
  instituteRecords TeacherInstituteRecord[]

  @@map("teacher_profile")
}

model StudentProfile {
  id               String                   @id @default(cuid())
  userId           String                   @unique
  headline         String?
  bio              String?                  @db.Text
  targetExam       String?
  currentClass     String?
  allowDMs         Boolean                  @default(true)
  isVisible        Boolean                  @default(true)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  instituteRecords StudentInstituteRecord[]

  @@map("student_profile")
}

model InstituteMembership {
  id            String                  @id @default(cuid())
  userId        String
  instituteId   String
  role          InstituteMemberRole
  status        MembershipStatus        @default(PENDING)
  joinedAt      DateTime?
  leftAt        DateTime?
  isActive      Boolean                 @default(true)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  institute     Institute               @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  studentRecord StudentInstituteRecord?
  teacherRecord TeacherInstituteRecord?

  @@unique([userId, instituteId, role])
  @@index([instituteId])
  @@index([userId])
  @@map("institute_membership")
}

model StudentInstituteRecord {
  id               String              @id @default(cuid())
  membershipId     String              @unique
  studentProfileId String
  instituteId      String
  courseName       String?
  batchYear        Int?
  passoutYear      Int?
  rollNumber       String?
  bio              String?             @db.Text
  isVerified       Boolean             @default(false)
  isVisible        Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  membership       InstituteMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  studentProfile   StudentProfile      @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  institute        Institute           @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  batchMemberships BatchStudent[]

  @@unique([studentProfileId, instituteId])
  @@index([instituteId])
  @@map("student_institute_record")
}

model TeacherInstituteRecord {
  id               String              @id @default(cuid())
  membershipId     String              @unique
  teacherProfileId String
  instituteId      String
  designation      String?
  department       String?
  teachingSubjects String[]            @default([])
  joinedOn         DateTime?
  bio              String?             @db.Text
  isFeatured       Boolean             @default(false)
  isVerified       Boolean             @default(false)
  displayOrder     Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  membership       InstituteMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  teacherProfile   TeacherProfile      @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  institute        Institute           @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  batchMemberships BatchTeacher[]

  @@unique([teacherProfileId, instituteId])
  @@index([instituteId])
  @@map("teacher_institute_record")
}

enum InstituteMemberRole {
  STUDENT
  TEACHER
  MANAGER
  ADMIN
}

enum MembershipStatus {
  PENDING
  ACTIVE
  ALUMNI
  REMOVED
  REJECTED
}

enum ConversationType {
  DIRECT
  INSTITUTE
  BATCH
  GROUP
  AI
}

model Conversation {
  id             String                    @id @default(cuid())
  type           ConversationType
  dmKey          String?                   @unique
  instituteId    String?
  batchId        String?
  channelType    ChannelType?
  title          String?
  imageUrl       String?
  description    String?
  createdById    String?
  visibility     ConversationVisibility    @default(PRIVATE)
  memberCount    Int                       @default(0)
  lastMessageId  String?
  lastMessageAt  DateTime?
  lastActivityAt DateTime?
  isReadOnly     Boolean                   @default(false)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  institute      Institute?                @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  batch          InstituteBatch?           @relation(fields: [batchId], references: [id], onDelete: Cascade)
  createdBy      User?                     @relation(fields: [createdById], references: [id])
  participants   ConversationParticipant[]
  messages       Message[]
  lastMessage    Message?                  @relation("LastMessage", fields: [lastMessageId], references: [id])

  @@index([type])
  @@index([instituteId])
  @@index([batchId])
  @@index([channelType])
  @@index([lastMessageAt])
  @@index([lastActivityAt])
  @@map("conversation")
}

enum ConversationVisibility {
  PRIVATE
  INSTITUTE
  PUBLIC
}

enum ChannelType {
  GENERAL
  STUDENTS
  TEACHERS
  ANNOUNCEMENTS
  BATCH
  CUSTOM
}

model ConversationParticipant {
  id                 String             @id @default(cuid())
  conversationId     String
  userId             String
  joinedAt           DateTime           @default(now())
  leftAt             DateTime?
  isMuted            Boolean            @default(false)
  isPinned           Boolean            @default(false)
  isArchived         Boolean            @default(false)
  lastReadMessageId  String?
  lastReadAt         DateTime?
  lastSeenAt         DateTime?
  role               ConversationRole   @default(MEMBER)
  status             ConversationStatus @default(ACTIVE)
  notificationsMuted Boolean            @default(false)
  isHidden           Boolean            @default(false)
  conversation       Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadMessage    Message?           @relation("ParticipantLastRead", fields: [lastReadMessageId], references: [id])

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
  @@map("conversation_participant")
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum MessageStatus {
  SENT
  FAILED
  DELETED
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  FILE
  AUDIO
  SYSTEM
}

model Message {
  id                   String                    @id @default(cuid())
  conversationId       String
  senderId             String
  type                 MessageType               @default(TEXT)
  content              String?                   @db.Text
  replyToId            String?
  isEdited             Boolean                   @default(false)
  editedAt             DateTime?
  deletedAt            DateTime?
  editedById           String?
  deletedById          String?
  isPinned             Boolean                   @default(false)
  isDeleted            Boolean                   @default(false)
  senderRoleSnapshot   InstituteMemberRole?
  searchText           String?
  senderNameSnapshot   String?
  senderAvatarSnapshot String?
  senderProfileId      String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  conversation         Conversation              @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender               User                      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo              Message?                  @relation("MessageReplies", fields: [replyToId], references: [id])
  replies              Message[]                 @relation("MessageReplies")
  status               MessageStatus             @default(SENT)
  attachments          MessageAttachment[]
  reactions            MessageReaction[]
  reads                MessageRead[]
  reports              MessageReport[]
  lastForConversation  Conversation[]            @relation("LastMessage")
  participantLastReads ConversationParticipant[] @relation("ParticipantLastRead")

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([replyToId])
  @@map("message")
}

model MessageAttachment {
  id              String   @id @default(cuid())
  messageId       String
  fileUrl         String
  fileName        String
  mimeType        String
  size            Int
  width           Int?
  height          Int?
  duration        Int?
  thumbnailUrl    String?
  storageProvider String?
  checksum        String?
  createdAt       DateTime @default(now())
  message         Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_attachment")
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
  @@map("message_reaction")
}

model MessageRead {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
  @@index([messageId])
  @@map("message_read")
}

model MessageReport {
  id           String           @id @default(cuid())
  messageId    String
  reporterId   String
  reason       String
  description  String?          @db.Text
  status       ChatReportStatus @default(PENDING)
  resolvedById String?
  resolvedAt   DateTime?
  adminNote    String?          @db.Text
  createdAt    DateTime         @default(now())
  message      Message          @relation(fields: [messageId], references: [id], onDelete: Cascade)
  reporter     User             @relation("Reporter", fields: [reporterId], references: [id])
  resolver     User?            @relation("Resolver", fields: [resolvedById], references: [id])

  @@index([messageId])
  @@index([reporterId])
  @@index([status])
  @@map("message_report")
}

enum ChatReportStatus {
  PENDING
  REVIEWED
  DISMISSED
  ACTION_TAKEN
}

model ChatSettings {
  id                   String  @id @default(cuid())
  userId               String  @unique
  allowDirectMessages  Boolean @default(true)
  allowMessageRequests Boolean @default(true)
  showOnlineStatus     Boolean @default(true)
  showLastSeen         Boolean @default(true)
  readReceiptsEnabled  Boolean @default(true)
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_settings")
}

model UserNotification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  entityId  String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notification")
}

enum NotificationType {
  MESSAGE
  MENTION
  REACTION
  NOTICE
  REVIEW
  SYSTEM
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  reason    String?
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
  blocker   User     @relation("UserBlocks", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("BlockedUsers", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@map("user_block")
}

enum ConversationRole {
  OWNER

  ADMIN

  MEMBER
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_message")
}

model InstituteRequest {
  id               String    @id @default(cuid())
  userId           String
  instituteId      String    @unique
  ownerName        String?
  ownerPhone       String?
  ownerDesignation String?
  status           String    @default("PENDING")
  createdAt        DateTime  @default(now())
  institute        Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [userId], references: [id])

  @@map("institute_request")
}

model SubscriptionPayment {
  id            String           @id @default(cuid())
  instituteId   String
  userId        String?
  planRequested SubscriptionPlan
  billingCycle  String
  amountPaid    Int
  utrNumber     String           @unique
  proofImageUrl String?
  status        String           @default("PENDING")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  institute     Institute        @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user          User?            @relation(fields: [userId], references: [id])

  @@map("subscription_payment")
}

model SalesAssignment {
  id             String            @id @default(cuid())
  salesManagerId String
  instituteId    String            @unique
  contactStatus  ContactStatus     @default(NOT_CONTACTED)
  interest       InterestStatus?
  remark         String?
  onboardedPlan  SubscriptionPlan?
  deadline       DateTime?
  contactedAt    DateTime?
  onboardedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
