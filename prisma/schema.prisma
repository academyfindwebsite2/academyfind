generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String             @id @default(cuid())
  name                String?
  email               String             @unique
  phone               String?
  passwordHash        String?
  image               String?
  role                Role               @default(USER)
  isActive            Boolean            @default(true)
  emailVerified       Boolean            @default(false)
  onboardingCompleted Boolean            @default(false)
  lastLoginAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  managedInstitutes   InstituteManager[]
  reviews             Review[]
  accounts            Account[]
  sessions            Session[]
  claims              InstituteClaim[]
  shortlisted         UserShortlist[]
  viewHistory         UserHistory[]
  canAddInstitute     Boolean            @default(true)
  instituteRequests          InstituteRequest[]
  payments                   SubscriptionPayment[]
  salesAssignments           SalesAssignment[]          @relation("SalesAssignments")
  salesCategoryAssignments   SalesCategoryAssignment[]  @relation("SalesCategoryAssignments")

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Institute {
  id                String              @id @default(cuid())
  name              String
  slug              String
  description       String?
  phone             String?
  email             String?
  website           String?
  address           String
  latitude          Float?
  longitude         Float?
  logo              String?
  coverImage        String?
  googlePlaceId     String?             @unique
  googleRating      Float?
  googleReviewCount Int?
  cityId            String
  isVerified        Boolean             @default(false)
  isFeatured        Boolean             @default(false)
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  imageUrl          String?
  averageRating     Float?              @default(0)
  reviewCount       Int                 @default(0)
  googleMapsUrl     String?
  placeTypes        String[]
  city              City                @relation(fields: [cityId], references: [id])
  categories        InstituteCategory[]
  managers          InstituteManager[]
  reviews           Review[]
  claims            InstituteClaim[]
  shortlistedBy     UserShortlist[]
  viewHistory       UserHistory[]
  gallery          String[]          // Basic Plan feature
  subscriptionPlan SubscriptionPlan  @default(BASIC) // Admin set karega
  
  enquiries        InstituteEnquiry[]           
  youtubeVideos     String[]           
  teachers          TeacherProfile[]

  feeInfo           String?            
  classroomImages   String[]

  instituteRequest  InstituteRequest?
  planExpiresAt     DateTime?
  payments          SubscriptionPayment[]
  salesAssignments  SalesAssignment[]

  facebookUrl       String?
  instagramUrl      String?
  twitterUrl        String?
  youtubeUrl        String?
  telegramUrl       String?
  linkedinUrl       String?
  whatsappUrl       String?

  @@index([cityId])
  @@index([slug])
}

model City {
  id         String      @id @default(cuid())
  name       String
  slug       String      @unique
  state      String
  country    String      @default("India")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  institutes Institute[]

  @@index([state])
}

model Category {
  id                        String                    @id @default(cuid())
  name                      String
  slug                      String                    @unique
  parentId                  String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  isActive                  Boolean                   @default(true)
  level                     Int                       @default(0)
  parent                    Category?                 @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children                  Category[]                @relation("CategoryHierarchy")
  institutes                InstituteCategory[]
  salesCategoryAssignments  SalesCategoryAssignment[]

  @@index([parentId])
}

model InstituteCategory {
  instituteId String
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@id([instituteId, categoryId])
  @@index([categoryId])
}

model InstituteManager {
  userId      String
  instituteId String
  createdAt   DateTime  @default(now())
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, instituteId])
  @@index([instituteId])
}

model Review {
  id          String    @id @default(cuid())
  rating      Int
  comment     String?
  userId      String
  instituteId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, instituteId])
  @@index([userId])
  @@index([instituteId])
}

enum Role {
  USER
  CONTENT_WRITER
  INSTITUTE_MANAGER
  SALES_MANAGER
  ADMIN
}

model InstituteClaim {
  id String @id @default(cuid())

  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName String
  email    String
  phone    String
  role     String
  message  String? @db.Text

  status String @default("PENDING") 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instituteId])
  @@index([userId])
  @@index([status])
  @@map("institute_claim")
}

model UserShortlist {
  userId      String
  instituteId String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@id([userId, instituteId])
  @@map("user_shortlist")
}

model UserHistory {
  id          String   @id @default(cuid())
  userId      String
  instituteId String
  viewedAt    DateTime @default(now()) @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_history")
}

enum SubscriptionPlan {
  BASIC
  PREMIUM
  ULTRA
  VERIFIED
}

model InstituteEnquiry {
  id          String    @id @default(cuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  
  name        String
  email       String
  phone       String
  message     String?   @db.Text
  status      String    @default("NEW") 
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([instituteId])
  @@map("institute_enquiry")
}

model TeacherProfile {
  id          String    @id @default(cuid())
  name        String
  subject     String?
  experience  String?
  imageUrl    String?
  
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@index([instituteId])
  @@map("teacher_profile")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String
  subject   String?
  message   String   @db.Text
  isRead    Boolean  @default(false) 
  createdAt DateTime @default(now())

  @@map("contact_message")
}

model InstituteRequest {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  instituteId String    @unique // 🚀 Binding direct Relation
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime  @default(now())

  @@map("institute_request")
}

model SubscriptionPayment {
  id              String           @id @default(cuid())
  instituteId     String
  institute       Institute        @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  planRequested   SubscriptionPlan // VERIFIED, PREMIUM, ULTRA
  billingCycle    String           // MONTHLY, ANNUAL
  amountPaid      Int
  utrNumber       String           @unique 
  proofImageUrl   String?          
  status          String           @default("PENDING") // PENDING, APPROVED, REJECTED
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("subscription_payment")
}

// ==========================================
// SALES MANAGER MODELS
// ==========================================

enum ContactStatus {
  NOT_CONTACTED
  CONTACTED
  ONBOARDED
}

enum InterestStatus {
  INTERESTED
  NOT_INTERESTED
}

model SalesAssignment {
  id              String            @id @default(cuid())

  salesManagerId  String
  salesManager    User              @relation("SalesAssignments", fields: [salesManagerId], references: [id], onDelete: Cascade)

  instituteId     String            @unique
  institute       Institute         @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  // Tracking
  contactStatus   ContactStatus     @default(NOT_CONTACTED)
  interest        InterestStatus?
  remark          String?           @db.Text
  onboardedPlan   SubscriptionPlan?

  deadline        DateTime?
  contactedAt     DateTime?
  onboardedAt     DateTime?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([salesManagerId])
  @@index([instituteId])
  @@index([contactStatus])
  @@map("sales_assignment")
}

model SalesCategoryAssignment {
  id              String    @id @default(cuid())

  salesManagerId  String
  salesManager    User      @relation("SalesCategoryAssignments", fields: [salesManagerId], references: [id], onDelete: Cascade)

  categoryId      String
  category        Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  deadline        DateTime?
  createdAt       DateTime  @default(now())

  @@unique([salesManagerId, categoryId])
  @@index([salesManagerId])
  @@map("sales_category_assignment")
}

enum LifeCoachRequestStatus {
  PENDING
  CONTACTED
  RESOLVED
}

model LifeCoachRequest {
  id        String   @id @default(cuid())
  fullName  String
  phone     String
  email     String
  message   String?
  status    LifeCoachRequestStatus  @default(PENDING) 
  createdAt DateTime @default(now())
}